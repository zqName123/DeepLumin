Panels:
  - Class: rviz/Displays
    Name: Displays
  - Class: rviz/Views
    Name: Views
Visualization Manager:
  Class: ""
  Displays:
    - Alpha: 0.5
      Autocompute Intensity Bounds: true
      Autocompute Value Bounds:
        Max Value: 10
        Min Value: -10
        Value: true
      Axis: Z
      Channel Name: intensity
      Class: rviz/PointCloud2
      Color: 200; 200; 200
      Color Transformer: FlatColor
      Decay Time: 0
      Enabled: true
      Name: GlobalMap
      Position Transformer: XYZ
      Queue Size: 1
      Selectable: true
      Size (Pixels): 2
      Size (m): 0.05
      Style: Points
      Topic: /offline_eval/global_map
      Unreliable: false
      Use Fixed Frame: true
      Use rainbow: false
    - Alpha: 0.9
      Autocompute Intensity Bounds: true
      Autocompute Value Bounds:
        Max Value: 10
        Min Value: -10
        Value: true
      Axis: Z
      Channel Name: intensity
      Class: rviz/PointCloud2
      Color: 255; 160; 0
      Color Transformer: FlatColor
      Decay Time: 0
      Enabled: true
      Name: QueryRaw
      Position Transformer: XYZ
      Queue Size: 1
      Selectable: true
      Size (Pixels): 3
      Size (m): 0.08
      Style: Points
      Topic: /offline_eval/query_raw
      Unreliable: false
      Use Fixed Frame: true
      Use rainbow: false
    - Alpha: 0.9
      Autocompute Intensity Bounds: true
      Autocompute Value Bounds:
        Max Value: 10
        Min Value: -10
        Value: true
      Axis: Z
      Channel Name: intensity
      Class: rviz/PointCloud2
      Color: 50; 255; 50
      Color Transformer: FlatColor
      Decay Time: 0
      Enabled: true
      Name: TruthAligned
      Position Transformer: XYZ
      Queue Size: 1
      Selectable: true
      Size (Pixels): 3
      Size (m): 0.08
      Style: Points
      Topic: /offline_eval/query_truth_aligned
      Unreliable: false
      Use Fixed Frame: true
      Use rainbow: false
    - Alpha: 0.9
      Autocompute Intensity Bounds: true
      Autocompute Value Bounds:
        Max Value: 10
        Min Value: -10
        Value: true
      Axis: Z
      Channel Name: intensity
      Class: rviz/PointCloud2
      Color: 0; 230; 230
      Color Transformer: FlatColor
      Decay Time: 0
      Enabled: true
      Name: ScInitialAligned
      Position Transformer: XYZ
      Queue Size: 1
      Selectable: true
      Size (Pixels): 3
      Size (m): 0.08
      Style: Points
      Topic: /offline_eval/query_sc_initial_aligned
      Unreliable: false
      Use Fixed Frame: true
      Use rainbow: false
    - Alpha: 0.9
      Autocompute Intensity Bounds: true
      Autocompute Value Bounds:
        Max Value: 10
        Min Value: -10
        Value: true
      Axis: Z
      Channel Name: intensity
      Class: rviz/PointCloud2
      Color: 255; 80; 50
      Color Transformer: FlatColor
      Decay Time: 0
      Enabled: true
      Name: RelocAligned
      Position Transformer: XYZ
      Queue Size: 1
      Selectable: true
      Size (Pixels): 3
      Size (m): 0.08
      Style: Points
      Topic: /offline_eval/query_reloc_aligned
      Unreliable: false
      Use Fixed Frame: true
      Use rainbow: false
    - Alpha: 0.4
      Autocompute Intensity Bounds: true
      Autocompute Value Bounds:
        Max Value: 10
        Min Value: -10
        Value: true
      Axis: Z
      Channel Name: intensity
      Class: rviz/PointCloud2
      Color: 80; 150; 255
      Color Transformer: FlatColor
      Decay Time: 0
      Enabled: true
      Name: GicpTarget
      Position Transformer: XYZ
      Queue Size: 1
      Selectable: true
      Size (Pixels): 2
      Size (m): 0.05
      Style: Points
      Topic: /offline_eval/gicp_target_submap
      Unreliable: false
      Use Fixed Frame: true
      Use rainbow: false
    - Class: rviz/MarkerArray
      Enabled: true
      Name: PoseMarkers
      Queue Size: 1
      Topic: /offline_eval/pose_markers
    - Class: rviz/Grid
      Enabled: true
      Name: Grid
      Plane: XY
      Plane Cell Count: 40
      Reference Frame: map
  Enabled: true
  Global Options:
    Background Color: 48; 48; 48
    Fixed Frame: map
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz/Interact
    - Class: rviz/MoveCamera
    - Class: rviz/FocusCamera
  Value: true
  Views:
    Current:
      Class: rviz/Orbit
      Distance: 120
      Focal Point:
        X: 0
        Y: 0
        Z: 0
      Name: Current View
      Pitch: 0.6
      Target Frame: map
      Yaw: 0.8
Window Geometry:
  Height: 900
  Width: 1400
