Panels:
  - Class: rviz/Displays
    Name: Displays
  - Class: rviz/Views
    Name: Views
Visualization Manager:
  Class: ""
  Displays:
    - Class: rviz/Grid
      Enabled: true
      Name: Grid
      Plane: XY
      Plane Cell Count: 120
      Reference Frame: map
    - Class: rviz/TF
      Enabled: true
      Name: TF
      Show Names: false
      Show Axes: true
      Show Arrows: true
      Marker Scale: 1
      Update Interval: 0
    - Class: rviz/PointCloud2
      Enabled: true
      Name: Global Map
      Topic: /localization/global_matcher/global_map
      Style: Points
      Size (m): 0.06
      Color Transformer: FlatColor
      Color: 95; 95; 95
    - Class: rviz/PointCloud2
      Enabled: true
      Name: Target Submap
      Topic: /localization/global_matcher/target_submap
      Style: Points
      Size (m): 0.08
      Color Transformer: FlatColor
      Color: 255; 190; 0
    - Class: rviz/PointCloud2
      Enabled: true
      Name: Source Scan Initial
      Topic: /localization/global_matcher/source_scan_initial
      Style: Points
      Size (m): 0.14
      Color Transformer: FlatColor
      Color: 255; 60; 60
    - Class: rviz/PointCloud2
      Enabled: true
      Name: Aligned Scan
      Topic: /localization/global_matcher/aligned_scan
      Style: Points
      Size (m): 0.13
      Color Transformer: FlatColor
      Color: 0; 190; 255
    - Class: rviz/Pose
      Enabled: true
      Name: Global Matcher Initial Guess
      Topic: /localization/global_matcher/initial_guess
      Shape: Arrow
      Axes Length: 2
      Axes Radius: 0.1
    - Class: rviz/Path
      Enabled: true
      Name: DR Path
      Topic: /localization/dr_path
      Color: 255; 130; 40
      Line Style: Lines
      Line Width: 0.04
    - Class: rviz/Path
      Enabled: true
      Name: SLAM Path
      Topic: /localization/path
      Color: 80; 180; 255
      Line Style: Lines
      Line Width: 0.05
    - Class: rviz/Path
      Enabled: true
      Name: Global Match Path
      Topic: /localization/global_matcher/path
      Color: 30; 255; 80
      Line Style: Lines
      Line Width: 0.07
    - Class: rviz/Path
      Enabled: true
      Name: Fused Path
      Topic: /localization/fused_path
      Color: 255; 255; 255
      Line Style: Lines
      Line Width: 0.09
    - Class: rviz/Path
      Enabled: true
      Name: Compare DR Map
      Topic: /localization/compare/dr_path_map
      Color: 255; 80; 30
      Line Style: Lines
      Line Width: 0.10
    - Class: rviz/Path
      Enabled: true
      Name: Compare SLAM Map
      Topic: /localization/compare/slam_path_map
      Color: 40; 160; 255
      Line Style: Lines
      Line Width: 0.10
    - Class: rviz/Path
      Enabled: true
      Name: Compare Fused Map
      Topic: /localization/compare/fused_path_map
      Color: 255; 255; 255
      Line Style: Lines
      Line Width: 0.12
    - Class: rviz/Odometry
      Enabled: true
      Name: Fused Odom
      Topic: /localization/fused_odom
      Shape: Arrow
      Position Tolerance: 0.1
      Angle Tolerance: 0.1
      Keep: 200
  Enabled: true
  Global Options:
    Background Color: 32; 32; 32
    Fixed Frame: map
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz/Interact
    - Class: rviz/MoveCamera
    - Class: rviz/FocusCamera
    - Class: rviz/SetInitialPose
      Topic: /initialpose
  Value: true
  Views:
    Current:
      Class: rviz/Orbit
      Distance: 120
      Focal Point:
        X: 0
        Y: 0
        Z: 0
      Name: Current View
      Pitch: 0.75
      Target Frame: map
      Yaw: 0.8
    Saved: ~
Window Geometry:
  Height: 920
  Width: 1500
