<launch>
  <arg name="config" default="$(find global_matcher)/config/global_matcher.yaml" />
  <arg name="pcd_path" default="/home/hhy/2004ros/relocalization_ws/global_map_manual_imu.pcd" />
  <arg name="keyframe_dir" default="/home/hhy/2004ros/relocalization_ws/key_point_frame" />
  <arg name="pose_file" default="/home/hhy/2004ros/relocalization_ws/optimized_poses_tum.txt" />
  <arg name="frame_index" default="1" />
  <arg name="initial_xyz_noise" default="10.0" />
  <arg name="initial_yaw_noise_deg" default="30.0" />
  <arg name="publish_rate" default="1.0" />
  <arg name="max_fitness_score" default="20.0" />
  <arg name="rviz" default="true" />

  <node pkg="global_matcher" type="global_matcher_viz_test_node" name="global_matcher_viz_test" output="screen">
    <rosparam file="$(arg config)" command="load" />
    <param name="runtime/viz_test_mode" value="true" />
    <param name="runtime/source_cloud_is_odom_frame" value="false" />
    <param name="runtime/match_rate" value="$(arg publish_rate)" />
    <param name="map/pcd_path" value="$(arg pcd_path)" />
    <param name="topics/source_cloud" value="/localization/cloud_registered" />
    <param name="topics/initial_pose" value="/localization/fused_odom" />
    <param name="topics/source_odom" value="/localization/slam_odom" />
    <param name="gate/max_fitness_score" value="$(arg max_fitness_score)" />
    <param name="gate/max_delta_translation" value="20.0" />
    <param name="gate/max_delta_yaw_deg" value="45.0" />
  </node>

  <node pkg="global_matcher" type="global_matcher_keyframe_test_node" name="global_matcher_keyframe_test" output="screen">
    <param name="keyframe_dir" value="$(arg keyframe_dir)" />
    <param name="pose_file" value="$(arg pose_file)" />
    <param name="frame_index" value="$(arg frame_index)" />
    <param name="publish_rate" value="$(arg publish_rate)" />
    <param name="initial_xyz_noise" value="$(arg initial_xyz_noise)" />
    <param name="initial_yaw_noise_deg" value="$(arg initial_yaw_noise_deg)" />
    <param name="map_frame" value="map" />
    <param name="base_frame" value="base_link" />
    <param name="source_frame" value="base_link" />
    <param name="cloud_topic" value="/localization/cloud_registered" />
    <param name="initial_pose_topic" value="/localization/fused_odom" />
    <param name="source_odom_topic" value="/localization/slam_odom" />
  </node>

  <node if="$(arg rviz)" pkg="rviz" type="rviz" name="global_matcher_rviz"
        args="-d $(find global_matcher)/rviz/global_matcher_viz.rviz" />
</launch>
